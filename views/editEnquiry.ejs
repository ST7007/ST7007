<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Enquiry</title>

<style>
* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #111;
  color: #fff;
  font-family: Arial, sans-serif;
  padding: 20px;
}

.container {
  max-width: 900px;
  margin: auto;
}

h1 {
  color: orange;
  text-align: center;
  margin-bottom: 20px;
}

form {
  background: #1a1a1a;
  padding: 25px;
  border-radius: 10px;
  box-shadow: 0 0 15px rgba(255,165,0,0.3);
}

label {
  display: block;
  margin-top: 14px;
  font-weight: bold;
}

input, select, textarea {
  width: 100%;
  padding: 10px;
  margin-top: 5px;
  border-radius: 6px;
  border: 2px solid orange;
  background: #fff;
  color: #000;
  font-size: 16px; /* prevents mobile zoom */
}

textarea {
  min-height: 80px;
  resize: vertical;
}

.row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

button {
  margin-top: 25px;
  padding: 14px;
  width: 100%;
  background: orange;
  color: #000;
  font-weight: bold;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 16px;
  transition: 0.3s;
}

button:hover {
  background: #333;
  color: #fff;
}

.back-link {
  display: block;
  margin-top: 20px;
  text-align: center;
  color: orange;
  text-decoration: none;
}

.back-link:hover {
  text-decoration: underline;
}

/* Mobile */
@media (max-width: 768px) {
  .row {
    grid-template-columns: 1fr;
  }
  body {
    padding: 12px;
  }
}
</style>
</head>

<body>

<div class="container">
<h1>Edit Customer Enquiry</h1>

<form action="/admin/enquiries/edit/<%= enquiry.id %>" method="POST">

  <div class="row">
    <div>
      <label>Full Name *</label>
      <input type="text" name="fullName" value="<%= enquiry.fullName %>" required>
    </div>

    <div>
      <label>Company Name</label>
      <input type="text" name="companyName" value="<%= enquiry.companyName %>">
    </div>
  </div>

  <div class="row">
    <div>
      <label>Email *</label>
      <input type="email" name="email" value="<%= enquiry.email %>" required>
    </div>

    <div>
      <label>Mobile *</label>
      <input type="text" name="mobile" value="<%= enquiry.mobile %>" required>
    </div>
  </div>

  <div class="row">
    <div>
      <label>Pickup Date *</label>
      <input type="date" name="pickupDate" value="<%= enquiry.pickupDate %>" required>
    </div>

    <div>
      <label>Pickup Time</label>
      <input type="time" name="pickupTime" value="<%= enquiry.pickupTime %>">
    </div>
  </div>

  <div class="row">
    <div>
      <label>Origin *</label>
      <input type="text" name="origin" value="<%= enquiry.origin %>" required>
    </div>

    <div>
      <label>Destination *</label>
      <input type="text" name="destination" value="<%= enquiry.destination %>" required>
    </div>
  </div>

  <div class="row">
    <div>
      <label>Adult</label>
      <input type="number" name="adult" min="0" value="<%= enquiry.adult %>">
    </div>

    <div>
      <label>Child &lt;4</label>
      <input type="number" name="childUnder4" min="0" value="<%= enquiry.childUnder4 %>">
    </div>
  </div>

  <div class="row">
    <div>
      <label>Child 4-7</label>
      <input type="number" name="child4to7" min="0" value="<%= enquiry.child4to7 %>">
    </div>

    <div>
      <label>Small Luggage</label>
      <input type="number" name="smallLuggage" min="0" value="<%= enquiry.smallLuggage %>">
    </div>
  </div>

  <div class="row">
    <div>
      <label>Medium Luggage</label>
      <input type="number" name="mediumLuggage" min="0" value="<%= enquiry.mediumLuggage %>">
    </div>

    <div>
      <label>Large Luggage</label>
      <input type="number" name="largeLuggage" min="0" value="<%= enquiry.largeLuggage %>">
    </div>
  </div>

  <label>Vehicle Type *</label>
  <input type="text" name="vehicleType" value="<%= enquiry.vehicleType %>" required>

  <label>Special Requirements</label>
  <textarea name="specialRequirements"><%= enquiry.specialRequirements %></textarea>

  <label>Status *</label>
  <select name="status" required>
      <option value="Pending" <%= enquiry.status==='Pending'?'selected':'' %>>Pending</option>
      <option value="Assigned" <%= enquiry.status==='Assigned'?'selected':'' %>>Assigned</option>
      <option value="Completed" <%= enquiry.status==='Completed'?'selected':'' %>>Completed</option>
  </select>

  <button type="submit">Update Enquiry</button>

</form>

<a class="back-link" href="/admin/enquiries">← Back to Enquiries</a>

</div>

</body>
</html>
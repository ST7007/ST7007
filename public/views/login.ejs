<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Super Admin Login</title>

<style>

body{
    font-family: Arial;
    background:#111;
    color:#fff;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.login-box{
    background:#1b1b1b;
    padding:40px;
    border-radius:10px;
    width:320px;
    text-align:center;
    box-shadow:0 0 15px rgba(0,0,0,0.6);
}

h2{
    margin-bottom:25px;
    color:orange;
}

input{
    width:100%;
    padding:12px;
    margin-bottom:15px;
    border:none;
    border-radius:5px;
}

button{
    width:100%;
    padding:12px;
    background:orange;
    border:none;
    border-radius:5px;
    font-weight:bold;
    cursor:pointer;
}

button:hover{
    background:#ff9900;
}

</style>

</head>

<body>

<div class="login-box">

<h2>Super Admin Login</h2>

<form method="POST" action="/admin/login">

<input name="username" placeholder="Username" required>

<input type="password" name="password" placeholder="Password" required>

<button type="submit">Login</button>

</form>

</div>

</body>
</html>